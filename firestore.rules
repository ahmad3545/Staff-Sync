rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own user document.
    // Admins can read and write any user document.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read tasks assigned to them.
    // Admins can create, read, update, and delete any task.
    match /tasks/{taskId} {
      allow read: if request.auth != null && (
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
                    resource.data.userId == request.auth.uid ||
                    (taskId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedTasks)
                  );
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Allow admins to read the admin_logs collection
    match /admin_logs/{logId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
